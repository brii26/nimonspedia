# PostgreSQL
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=nimonspedia
POSTGRES_USER=nimonspedia_user
POSTGRES_PASSWORD=nimonspedia_pass

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# Node.js Server
NODE_PORT=3000
NODE_LOCAL_PORT=3000

# JWT
JWT_SECRET=change_me_secret

# VAPID (Web Push Notifications) — generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@nimonspedia.com

# Internal API (PHP <-> Node communication)
INTERNAL_API_KEY=nimonspedia-internal-key
NODE_INTERNAL_URL=http://node-server:3000

# Client URL (used by Node for CORS & push callbacks)
CLIENT_URL=http://localhost:8080

# Midtrans Payment Gateway
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
MIDTRANS_IS_PRODUCTION=false

# Nginx
NGINX_PORT=8080
